# URL publique du backend FastAPI. Le navigateur n'appelle QUE cette API.
# (Variable NEXT_PUBLIC_* : elle est inlinee dans le bundle client au build.)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Nom du cookie de session httpOnly pose par le backend.
# Lu UNIQUEMENT par middleware.ts pour verifier la PRESENCE d'une session
# (la validation reelle du jeton reste faite par le backend).
AUTH_COOKIE_NAME=gb_access
