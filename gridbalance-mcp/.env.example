# Connexion MongoDB (Atlas). Defaut = meme cluster que le reste du projet.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.snap5mi.mongodb.net/?appName=Cluster0
MONGODB_DB=gridbalance

# Hote/port du serveur MCP (endpoint SSE : http://127.0.0.1:8100/sse).
MCP_HOST=127.0.0.1
MCP_PORT=8100

# E-mail (Agent 4 Journal). Optionnel : sans ces variables, l'envoi est ignore.
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
