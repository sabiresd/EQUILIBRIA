# =============================================================================
# GridBalance AI Morocco — configuration
#
#   cp .env.example .env
#
# Les valeurs par defaut permettent de lancer le projet EN LOCAL sans rien
# installer d'autre que Python et Node : base de donnees en memoire, e-mails
# ecrits en fichiers, agents simules.
#
# Donnees et couts : DEMONSTRATION uniquement (MAD). Aucune donnee reelle ONEE/ANRE.
# =============================================================================

# -----------------------------------------------------------------------------
# LES 4 AGENTS DE LA PLATEFORME AGENTIQUE
# -----------------------------------------------------------------------------
# stub -> le backend simule les 4 agents en interne, avec des donnees realistes
#         et deterministes. L'application tourne HORS LIGNE.
# live -> le backend appelle reellement les 4 webhooks ci-dessous.
WF_MODE=stub

# Webhooks POST des 4 agents, exposes par votre plateforme agentique
# (ABA Fusion / Langflow). Endpoint typique :
#   https://<votre-instance>/api/v1/webhook/<flow_id>
# A ne renseigner que si WF_MODE=live.
#
#   WF-1 Simulateur : meteo -> production eolienne/solaire + demande (360 h)
#   WF-2 Calcul     : bilan horaire, dispatch batterie, deficits, couts
#   WF-3 Plan       : 3 plans candidats A/B/C avec citations RAG (seul avec LLM)
#   WF-4 Journal    : journalisation + hash SHA-256 + notifications
WF1_URL=
WF2_URL=
WF3_URL=
WF4_URL=

WF_TIMEOUT_SECONDS=60
# Tentatives SUPPLEMENTAIRES en cas d'echec (backoff exponentiel : 1 s, 2 s, ...).
WF_RETRIES=2

# -----------------------------------------------------------------------------
# BASE DE DONNEES
# -----------------------------------------------------------------------------
# memory                        -> base EN MEMOIRE, aucune installation requise.
#                                  ATTENTION : les donnees sont perdues a l'arret
#                                  du backend (runs, decisions, journal d'audit).
# mongodb://localhost:27017     -> MongoDB installe sur votre machine.
# mongodb+srv://user:pass@...   -> MongoDB Atlas (persistant, gratuit).
MONGO_URL=memory
MONGO_DB=gridbalance

# -----------------------------------------------------------------------------
# E-MAIL
# -----------------------------------------------------------------------------
# file -> l'e-mail est ECRIT dans backend/outbox/<horodatage>.html, a ouvrir dans
#         un navigateur. Aucun serveur SMTP requis. C'est le defaut en local.
# smtp -> envoi reel via le serveur ci-dessous (Mailhog, Gmail, ...).
MAIL_MODE=file

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=gridbalance@demo.ma
SMTP_TLS=false

# Notifications Slack (optionnel). Laisser vide pour desactiver.
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# SECURITE
# -----------------------------------------------------------------------------
# Cle de signature des JWT. A CHANGER IMPERATIVEMENT hors demo.
# Generer une cle : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
# Requetes par minute et par utilisateur authentifie (par IP si anonyme).
RATE_LIMIT_PER_MINUTE=30
# Origines autorisees a appeler l'API avec les cookies de session.
CORS_ORIGINS=http://localhost:3000

# Connexion OIDC : structure prete, desactivee par defaut.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# SEUILS D'ALERTE (modifiables ensuite depuis la page Admin)
# -----------------------------------------------------------------------------
# Deficit de pointe declenchant une alerte critique, en MW. 1.5 est calibre sur le
# site de demo (besoin 6-15 MW) : le scenario "sans vent" culmine a ~1.9 MW et le
# scenario "normal" a 0. Un seuil plus haut ne declencherait jamais l'alerte.
ALERT_DEFICIT_THRESHOLD_MW=1.5
# Etat de charge de la batterie sous lequel une alerte est levee (fraction 0 a 1).
ALERT_SOC_THRESHOLD=0.15

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
APP_PUBLIC_URL=http://localhost:3000
